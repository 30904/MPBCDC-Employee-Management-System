PORT=5000
API_BASE_PATH=/api
# Local: mongodb://127.0.0.1:27017/mpbcdc_hrms
# Atlas (from Heramb): mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/mpbcdc_hrms
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=8h
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5
# Storage: local disk (uploads/). S3 can be wired in production.
